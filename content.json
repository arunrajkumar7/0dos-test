  ],
  "blocks": [
    {
      "id": "f9043175-b842-4b00-afd2-2348e98c04bc",
      "section_id": "243759ea-d213-4fa4-bc79-8e49615652b8",
      "type": "paragraph",
      "content": {
        "text": "Get up and running with Agentation in under 5 minutes."
      },
      "order_index": 0
    },
    {
      "id": "d3d8f3db-070f-453d-a8c5-1ee35c838cf6",
      "section_id": "22cd7146-e5f1-4f17-97bf-35258e0f2a6c",
      "type": "youtube",
      "content": {
        "url": "https://www.youtube.com/embed/dQw4w9WgXcQ",
        "caption": "A 3-minute walkthrough of the core features."
      },
      "order_index": 0
    },
    {
      "id": "e5689ca7-0d58-4839-84cb-a8ec9b42603b",
      "section_id": "1e40597c-2349-4cba-861c-892a2e7512c8",
      "type": "paragraph",
      "content": {
        "text": "1. Install the package"
      },
      "order_index": 0
    },
    {
      "id": "f01e0f08-f906-4ce1-a1b5-f46d6dc0700b",
      "section_id": "243759ea-d213-4fa4-bc79-8e49615652b8",
      "type": "unordered_list",
      "content": {
        "items": [
          "Node.js 18 or higher",
          "A modern browser (Chrome, Firefox, Safari, Edge)",
          "An AI coding tool (Claude Code, Cursor, Copilot, etc.)",
          ""
        ]
      },
      "order_index": 1
    },
    {
      "id": "b370d703-303b-4cff-95bc-e349e7dc955e",
      "section_id": "1e40597c-2349-4cba-861c-892a2e7512c8",
      "type": "code_block",
      "content": {
        "code": "npm install agentation\n# or\npnpm add agentation",
        "language": "bash"
      },
      "order_index": 1
    },
    {
      "id": "f91ac87b-51d7-4c12-ad69-cf25df3c83b2",
      "section_id": "1e40597c-2349-4cba-861c-892a2e7512c8",
      "type": "paragraph",
      "content": {
        "text": "2. Add to your project"
      },
      "order_index": 2
    },
    {
      "id": "5d0c7e5b-5c4b-428a-9f7a-4061e767ec1d",
      "section_id": "243759ea-d213-4fa4-bc79-8e49615652b8",
      "type": "video",
      "content": {
        "url": ""
      },
      "order_index": 2
    },
    {
      "id": "e11b7dbf-e1f4-4b23-9928-628bdafa2c85",
      "section_id": "243759ea-d213-4fa4-bc79-8e49615652b8",
      "type": "note",
      "content": {
        "text": "Add a sdfsdfg"
      },
      "order_index": 3
    },
    {
      "id": "4c28cbc6-3c47-4310-b1ff-13b11761790b",
      "section_id": "1e40597c-2349-4cba-861c-892a2e7512c8",
      "type": "code_block",
      "content": {
        "code": "import { Agentation } from 'agentation';\n\nconst agent = new Agentation({\n  projectId: 'my-project',\n  theme: 'auto',\n});\n\nagent.start();",
        "language": "typescript"
      },
      "order_index": 3
    },
    {
      "id": "bada62de-74b9-4c8d-a4bb-887d01662034",
      "section_id": "1e40597c-2349-4cba-861c-892a2e7512c8",
      "type": "paragraph",
      "content": {
        "text": "3. Open your app in the browser and click the toolbar icon."
      },
      "order_index": 4
    },
    {
      "id": "80c8e13a-9179-47a6-a345-a045290b9d2d",
      "section_id": "1e40597c-2349-4cba-861c-892a2e7512c8",
      "type": "note",
      "content": {
        "text": "The toolbar only appears in development mode by default. See Configuration for production options."
      },
      "order_index": 5
    },
    {
      "id": "fec773ad-90d8-44b4-a516-3c2bd7a79a4a",
      "section_id": "1e40597c-2349-4cba-861c-892a2e7512c8",
